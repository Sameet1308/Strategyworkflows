def login(base_url: str, username: str, password: str) -> str:
“””
POST /api/auth/login.
Returns auth token string.
Raises ValueError on failure so the caller can skip this environment.
“””
url = f”{base_url}/api/auth/login”
try:
resp = requests.post(
url,
json={“username”: username, “password”: password, “loginMode”: LOGIN_MODE},
headers={“Content-Type”: “application/json”},
verify=SSL_VERIFY,
timeout=30,
)
resp.raise_for_status()
token = resp.headers.get(“X-MSTR-AuthToken”, “”)
if not token:
raise ValueError(“Login succeeded but X-MSTR-AuthToken was missing in response headers.”)
return token
except requests.exceptions.ConnectionError:
raise ValueError(
f”Cannot connect to {url}. “
“Verify the URL, VPN, and that MicroStrategy Library is running.”
)
except requests.exceptions.HTTPError as e:
raise ValueError(f”Login HTTP error: {e}”)
except Exception as e:
raise ValueError(f”Login failed: {e}”)

