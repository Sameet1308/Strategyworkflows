# ★ PAGINATED FOLDER CONTENTS

# Handles MSTR folders with hundreds of children by looping through pages.

# Uses offset+limit until all items are retrieved.

# =============================================================================

def get_folder_children(
base_url: str, token: str, project_id: str, folder_id: str
) -> list:
“””
GET /api/folders/{id} with pagination.
Retrieves ALL child items of type Folder (type=8) across all pages.
Returns list of {“id”: …, “name”: …} dicts.
Never raises — returns [] on any error.
“””
all_children = []
offset       = 0

```
while True:
    data, err = safe_get(
        f"{base_url}/api/folders/{folder_id}",
        token,
        project_id=project_id,
        params={"fields": "id,name,type", "limit": PAGE_LIMIT, "offset": offset},
    )
    if err:
        log.warning(f"    [WARN] Folder contents fetch failed (id={folder_id}, offset={offset}): {err}")
        break

    # API returns either a list directly or a dict with a 'contents' key
    if isinstance(data, list):
        page_items = data
    elif isinstance(data, dict):
        page_items = data.get("contents", [])
    else:
        log.warning(f"    [WARN] Unexpected folder contents type for id={folder_id}: {type(data)}")
        break

    # Filter to folders only
    folder_items = [
        i for i in page_items
        if isinstance(i, dict) and i.get("type") == FOLDER_TYPE
    ]
    all_children.extend(folder_items)

    # If the page returned fewer items than PAGE_LIMIT, we're on the last page
    if len(page_items) < PAGE_LIMIT:
        break

    offset += PAGE_LIMIT

return all_children
```

