def decode_rights(rights: int) -> dict:
“””
Decode a rights integer into individual permission names and a
plain-English combo label.
Always returns a dict with: permissions_list, permissions_decoded,
combo_description.  Never raises.
“””
try:
rights = int(rights)
except (TypeError, ValueError):
rights = 0

```
if rights >= 255:
    return {
        "permissions_list":    ["Full Control"],
        "permissions_decoded": "Full Control",
        "combo_description":   COMMON_RIGHTS_COMBOS[255],
    }
if rights == 0:
    return {
        "permissions_list":    [],
        "permissions_decoded": "No Permissions (0)",
        "combo_description":   COMMON_RIGHTS_COMBOS[0],
    }
individual = [label for bit, label in RIGHTS_BITS.items() if rights & bit]
combo = COMMON_RIGHTS_COMBOS.get(rights, " + ".join(individual))
return {
    "permissions_list":    individual,
    "permissions_decoded": ", ".join(individual) if individual else "No Permissions (0)",
    "combo_description":   combo,
}
```

def decode_trustee_type(type_int) -> str:
try:
return TRUSTEE_TYPE_DESC.get(int(type_int), f”Unknown type ({type_int})”)
except (TypeError, ValueError):
return f”Unknown type ({type_int})”

def decode_trustee_subtype(subtype_int) -> str:
try:
return TRUSTEE_SUBTYPE_DESC.get(int(subtype_int), f”Unknown subtype ({subtype_int})”)
