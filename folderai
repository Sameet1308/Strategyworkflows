        # ── Per-environment exports ────────────────────────────────────────
        log.info(
            f"\n  {env}: {len(env_acl_records):,} ACL records, "
            f"{len(env_membership):,} membership records"
        )
        log.info("  Exporting...")
        export_json(env, server, env_acl_records, env_membership, generated_at)
        export_markdown(env, server, env_acl_records, env_membership, generated_at)

        all_env_acl_records.extend(env_acl_records)
        all_env_membership.extend(env_membership)

    except ValueError as exc:
        # Login failures raise ValueError with a clear message
        log.error(f"  ❌ {env}: {exc}")
    except Exception as exc:
        log.error(f"  ❌ Unexpected error for {env}: {exc}", exc_info=True)
    finally:
        if token:
            logout(base_url, token)
            log.info(f"  Session closed for {env}")

# ── Combined exports across all environments ───────────────────────────────
log.info(f"\n{'─' * 60}")
log.info("  Writing combined output files...")
export_acl_csv(all_env_acl_records)
export_membership_csv(all_env_membership)

elapsed = (datetime.now() - run_start).total_seconds()
log.info(f"\n{'=' * 68}")
log.info("  AUDIT COMPLETE")
log.info(f"  Total ACL records    : {len(all_env_acl_records):,}")
log.info(f"  Total members        : {len(all_env_membership):,}")
log.info(f"  Elapsed              : {elapsed:.1f}s")
log.info(f"  Output dir           : {OUTPUT_DIR.resolve()}")
log.info("=" * 68)
