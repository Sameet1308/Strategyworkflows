def get_all_root_folders(base_url: str, token: str, project_id: str) -> list:
“””
Try every predefined root folder type ID and collect unique folders.
Deduplicates by folder GUID — same physical folder never walked twice.
Returns list of {“id”: …, “label”: …, “description”: …}
“””
seen_ids   = set()
discovered = []

```
for predef in PREDEFINED_ROOT_FOLDERS:
    type_id     = predef["type_id"]
    label       = predef["label"]
    description = predef["description"]

    data, err = safe_get(
        f"{base_url}/api/folders/preDefined/{type_id}",
        token,
        project_id=project_id,
    )
    if err:
        log.debug(f"      preDefined/{type_id} ({label}): {err}")
        continue

    folder_id = data.get("id") if isinstance(data, dict) else None
    if not folder_id:
        log.debug(f"      preDefined/{type_id} ({label}): no id in response")
        continue
    if folder_id in seen_ids:
        log.debug(f"      preDefined/{type_id} ({label}): duplicate id {folder_id}, skipped")
        continue

    seen_ids.add(folder_id)
    discovered.append({"id": folder_id, "label": label, "description": description})
    log.info(f"      ✅ Root folder: {label}  (id: {folder_id})")

if not discovered:
    log.warning(f"    [WARN] No predefined root folders resolved for project {project_id}")
return discovered
```

