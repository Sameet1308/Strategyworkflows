def decode_ace_type(type_int) -> str:
try:
return ACE_TYPE_DESC.get(int(type_int), f”Unknown ACE type ({type_int})”)
except (TypeError, ValueError):
return f”Unknown ACE type ({type_int})”

def decode_inheritable(flag) -> str:
return (
“Inheritable — new objects in this folder will receive this ACE”
if bool(flag)
else “Not inheritable — applies to this folder only”
)

def trustee_category(subtype_int) -> str:
try:
return (
“User Group (AD/LDAP)”
if int(subtype_int) == 8705
else “Individual User Account”
)
except (TypeError, ValueError):
return “Unknown”

