def parse_acl_entries(
acl_raw: list, source_label: str, source_detail: str
) -> list:
“””
Filter and decode raw ACL entries.
Includes: user groups (8705) and individual users (8704).
Excludes: all other trustee types.
All numeric fields are decoded to human-readable descriptions.
Never raises.
“””
if not isinstance(acl_raw, list):
return []

```
entries = []
for entry in acl_raw:
    if not isinstance(entry, dict):
        continue

    trustee_subtype = entry.get("trusteeSubtype", 0)

    try:
        trustee_subtype = int(trustee_subtype)
    except (TypeError, ValueError):
        trustee_subtype = 0

    if trustee_subtype not in INCLUDED_TRUSTEE_SUBTYPES:
        continue   # skip system objects and unknown trustee types

    trustee_type  = entry.get("trusteeType", 34)
    rights        = entry.get("rights", 0)
    ace_type      = entry.get("type", 1)
    inheritable   = bool(entry.get("inheritable", False))
    deny          = bool(entry.get("deny", False))
    rights_info   = decode_rights(rights)

    entries.append({
        "group":                entry.get("trusteeName", "Unknown"),
        "trustee_id":           entry.get("trusteeId", ""),
        "trustee_type_int":     trustee_type,
        "trustee_type_desc":    decode_trustee_type(trustee_type),
        "trustee_subtype_int":  trustee_subtype,
        "trustee_subtype_desc": decode_trustee_subtype(trustee_subtype),
        "trustee_category":     trustee_category(trustee_subtype),
        "ace_type_int":         ace_type,
        "ace_type_desc":        decode_ace_type(ace_type),
        "rights_int":           rights,
        "permissions_list":     rights_info["permissions_list"],
        "permissions_decoded":  rights_info["permissions_decoded"],
        "combo_description":    rights_info["combo_description"],
        "inheritable":          inheritable,
        "inheritable_desc":     decode_inheritable(inheritable),
        "deny":                 deny,
        "acl_source":           source_label,
        "acl_source_detail":    source_detail,
    })
return entries
```

def merge_effective_acl(direct: list, inherited: list) -> list:
“””
Merge direct + inherited ACL entries.
Direct entries win on duplicate group names.
Never raises.
“””
seen = {}
for entry in (direct or []):
if isinstance(entry, dict):
seen[entry.get(“group”, “”)] = entry
for entry in (inherited or []):
if isinstance(entry, dict):
key = entry.get(“group”, “”)
if key not in seen:
seen[key] = entry
return list(seen.values())

