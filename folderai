def safe_get(url: str, token: str, project_id: str = “”, params: dict = None) -> tuple:
“””
Perform a GET request with auth headers.
Returns (parsed_json, None) on success.
Returns (None, error_message) on any failure.
Never raises.
“””
headers = {“X-MSTR-AuthToken”: token}
if project_id:
headers[“X-MSTR-ProjectID”] = project_id
try:
resp = requests.get(
url,
headers=headers,
params=params or {},
verify=SSL_VERIFY,
timeout=30,
)
resp.raise_for_status()
return resp.json(), None
except requests.exceptions.Timeout:
return None, f”Timeout on GET {url}”
except requests.exceptions.ConnectionError as e:
return None, f”Connection error on GET {url}: {e}”
except requests.exceptions.HTTPError as e:
return None, f”HTTP {e.response.status_code} on GET {url}: {e}”
except ValueError as e:
return None, f”JSON decode error on GET {url}: {e}”
except Exception as e:
return None, f”Unexpected error on GET {url}: {e}”

