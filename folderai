def walk_folder(
base_url: str,
token: str,
project_id: str,
project_name: str,
folder_id: str,
folder_name: str,
env: str,
server: str,
parent_path: str,
parent_effective_acl: list,
all_records: list,
depth: int,
max_depth: int,
generated_at: str,
) -> None:
“””
Recursively walk a folder tree collecting ACL records.
- Fetches this folder’s direct ACL
- Builds inherited ACL from parent’s effective ACL
- Merges to produce effective ACL (direct wins)
- Recurses into child folders if depth < max_depth
- Pagination handled by get_folder_children()
- All errors caught and logged — never raises
“””
try:
folder_path = f”{parent_path} > {folder_name}” if parent_path else folder_name
log.info(f”    {’  ’ * depth}📁 [depth {depth}] {folder_path}”)

```
    # ── Direct ACL for this folder ─────────────────────────────────────────
    acl_raw    = fetch_folder_acl_raw(base_url, token, project_id, folder_id)
    direct_acl = parse_acl_entries(
        acl_raw,
        source_label="direct",
        source_detail="Assigned directly on this folder",
    )

    # ── Inherited ACL = parent effective re-labeled ────────────────────────
    inherited_acl = []
    for entry in (parent_effective_acl or []):
        if not isinstance(entry, dict):
            continue
        inh = deepcopy(entry)
        inh["acl_source"]        = "inherited"
        inh["acl_source_detail"] = f"inherited_from: {parent_path or 'project root'}"
        inherited_acl.append(inh)

    # ── Effective = direct wins, fill from inherited ───────────────────────
    effective_acl = merge_effective_acl(direct_acl, inherited_acl)

    # ── Child folders (paginated) ──────────────────────────────────────────
    child_folders = []
    if depth < max_depth:
        child_folders = get_folder_children(base_url, token, project_id, folder_id)

    # ── Build record ───────────────────────────────────────────────────────
    record = {
        "environment":    env,
        "server":         server,
        "project":        project_name,
        "project_id":     project_id,
        "folder_name":    folder_name,
        "folder_path":    folder_path,
        "folder_id":      folder_id,
        "depth":          depth,
        "record_type":    "folder_acl",
        "direct_acl":     direct_acl,
        "inherited_acl":  inherited_acl,
        "effective_acl":  effective_acl,
        "children":       [c.get("name", "") for c in child_folders],
        "generated_at":   generated_at,
        "markdown_chunk": "",
    }
    record["markdown_chunk"] = build_markdown_chunk(record)
    all_records.append(record)

    # ── Recurse ────────────────────────────────────────────────────────────
    for child in child_folders:
        child_id   = child.get("id", "")
        child_name = child.get("name", "")
        if not child_id or not child_name:
            continue
        walk_folder(
            base_url, token, project_id, project_name,
            child_id, child_name,
            env, server,
            folder_path,
            effective_acl,
            all_records,
            depth + 1, max_depth,
            generated_at,
        )

except Exception as exc:
    log.warning(
        f"    [WARN] walk_folder failed at depth {depth} "
        f"folder_id={folder_id} name='{folder_name}': {exc}"
    )
