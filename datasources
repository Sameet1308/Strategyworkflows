# “””
MSTR Datasource Audit Script

Discovers all datasources, flags environment (PROD/DEV/UAT/DISC/etc.),
maps which projects each datasource belongs to, and checks dependencies.

Outputs:

- mstr_datasource_audit_YYYYMMDD_HHMMSS.csv   (main report)
- raw_datasources.json                          (for troubleshooting)
- raw_connections.json
- raw_logins.json
- raw_projects.json

Usage:
python mstr_datasource_audit.py
“””

import requests
import json
import csv
import re
import time
from datetime import datetime

requests.packages.urllib3.disable_warnings()

# ── CONFIG ────────────────────────────────────────────────────────────────────

BASE_URL = “https://your-mstr-server/MicroStrategyLibrary/api”
USERNAME = “administrator”
PASSWORD = “your_password”

OUTPUT_CSV = f”mstr_datasource_audit_{datetime.now().strftime(’%Y%m%d_%H%M%S’)}.csv”

# Object type number for database instance (DssXmlTypeDBRole = 3)

DB_INSTANCE_TYPE = 3

# ── ENV DETECTION PATTERNS ────────────────────────────────────────────────────

# Checked case-insensitively against datasource name, connection name,

# login name, and connection string — in that priority order.

# Add or adjust patterns here to match your naming conventions.

ENV_PATTERNS = [
(r’*pd\b|*prd\b|*prod\b|\bprod\b|\bproduction\b|pd*|prd*|prod*’, ‘PROD’),
(r’*dev\b|\bdev\b|*dv\b|\bdevelopment\b|dev*|dv*’,               ‘DEV’),
(r’*uat\b|\buat\b|uat*’,                                          ‘UAT’),
(r’*disc\b|\bdisco\b|\bdiscovery\b|disc*’,                        ‘DISC’),
(r’*stg\b|*stage\b|\bstaging\b|stg*|stage*’,                     ‘STAGE’),
(r’*qa\b|\bqa\b|qa*’,                                             ‘QA’),
]

# ── AUTH ──────────────────────────────────────────────────────────────────────

def mstr_login(base_url, username, password):
resp = requests.post(
f”{base_url}/auth/login”,
json={“username”: username, “password”: password, “loginMode”: 1},
verify=False
)
resp.raise_for_status()
print(f”  ✅ Logged in as {username}”)
return resp.headers[“X-MSTR-AuthToken”]

def mstr_logout(base_url, auth_token):
requests.post(
f”{base_url}/auth/logout”,
headers={“X-MSTR-AuthToken”: auth_token},
verify=False
)
print(”  ✅ Logged out”)

# ── FETCH HELPERS ─────────────────────────────────────────────────────────────

def get_json(base_url, auth_token, path):
resp = requests.get(
f”{base_url}{path}”,
headers={“X-MSTR-AuthToken”: auth_token, “Accept”: “application/json”},
verify=False
)
resp.raise_for_status()
return resp.json()

def save_raw(data, filename):
with open(filename, “w”, encoding=“utf-8”) as f:
json.dump(data, f, indent=2)

# ── ENV DETECTION ─────────────────────────────────────────────────────────────

def detect_env(text, field_label):
“”“Run each pattern against text. Returns (env, matched_on) or (None, None).”””
if not text:
return None, None
for pattern, env in ENV_PATTERNS:
if re.search(pattern, text, re.IGNORECASE):
return env, f”{field_label}: ‘{text}’”
return None, None

def classify_datasource(ds_name, conn_name, login_name, conn_string):
“””
Try fields in priority order:
1. datasource name  (most reliable — admins usually suffix this)
2. connection name
3. login name
4. connection string  (last — long and noisy)
Returns (environment, matched_on_description)
“””
for text, label in [
(ds_name,     “datasource_name”),
(conn_name,   “connection_name”),
(login_name,  “login_name”),
(conn_string, “connection_string”),
]:
env, matched_on = detect_env(text, label)
if env:
return env, matched_on
return “UNKNOWN”, “no pattern matched — review manually”

# ── LOOKUP MAP BUILDERS ───────────────────────────────────────────────────────

def build_map(response, *list_keys):
“””
Extract a list from a response dict trying multiple key names,
then return a {id: item} dict.
“””
items = response
if isinstance(response, dict):
for key in list_keys:
if key in response:
items = response[key]
break
else:
# If none of the keys match, try the first list value we find
items = next(
(v for v in response.values() if isinstance(v, list)), []
)
return {item[“id”]: item for item in items if “id” in item}

# ── PROJECT → DATASOURCE MAPPING ─────────────────────────────────────────────

def build_project_datasource_map(base_url, auth_token, projects):
“””
For each project, call GET /api/projects/{projectId}/datasources.
Returns an inverted map: {datasource_id: [project_name, …]}
Also returns {project_id: project_name} for reference.
“””
ds_to_projects = {}   # datasource_id -> list of project names
project_names  = {}   # project_id -> project_name

```
for proj in projects:
    proj_id   = proj.get("id", "")
    proj_name = proj.get("name", "")
    if not proj_id:
        continue
    project_names[proj_id] = proj_name

    try:
        resp = get_json(base_url, auth_token, f"/projects/{proj_id}/datasources")
        # Response is {"datasources": [...]}
        ds_list = resp.get("datasources", resp if isinstance(resp, list) else [])
        for ds in ds_list:
            ds_id = ds.get("id", "")
            if ds_id:
                ds_to_projects.setdefault(ds_id, []).append(proj_name)
        print(f"    Project '{proj_name}': {len(ds_list)} datasource(s)")
    except requests.HTTPError as e:
        print(f"    ⚠️  Could not fetch datasources for project '{proj_name}': {e}")

return ds_to_projects, project_names
```

# ── DEPENDENCY CHECK ──────────────────────────────────────────────────────────

def check_dependencies(base_url, auth_token, datasource_id, obj_type=DB_INSTANCE_TYPE):
“””
Two-step metadata search:
POST /api/metadataSearches/results?usesObject={id};{type}
→ triggers search, stores results in IS memory
GET  /api/metadataSearches/results
→ retrieves stored results

```
Returns list of dependent objects (may be empty).
NOTE: searches cannot run in parallel in one session — sequential only.
"""
headers = {"X-MSTR-AuthToken": auth_token, "Accept": "application/json"}

# Step 1 — trigger search
post_resp = requests.post(
    f"{base_url}/metadataSearches/results",
    headers=headers,
    params={
        "domain": 2,
        "usesObject": f"{datasource_id};{obj_type}",
        "usesRecursive": "false"
    },
    verify=False
)
post_resp.raise_for_status()

# Brief pause for IS to complete the search
time.sleep(0.8)

# Step 2 — retrieve results
get_resp = requests.get(
    f"{base_url}/metadataSearches/results",
    headers=headers,
    verify=False
)
get_resp.raise_for_status()
data = get_resp.json()

# Results are usually under 'result' key as a list
return data.get("result", data if isinstance(data, list) else [])
```

def format_dependencies(dep_list):
“””
Flatten dependency list into two CSV-friendly strings:
dep_count       — integer count
dep_summary     — “TypeName: ObjName (ID) | TypeName: ObjName (ID) | …”
“””
count = len(dep_list)
if count == 0:
return 0, “none”
parts = []
for item in dep_list:
obj_type = item.get(“type”, “?”)
obj_name = item.get(“name”, “unknown”)
obj_id   = item.get(“id”, “unknown”)
parts.append(f”[type={obj_type}] {obj_name} ({obj_id})”)
return count, “ | “.join(parts)

