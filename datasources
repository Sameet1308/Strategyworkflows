if **name** == “**main**”:

```
print("\n" + "="*60)
print("  MSTR DATASOURCE AUDIT")
print("="*60)

auth_token = mstr_login(BASE_URL, USERNAME, PASSWORD)

try:
    # ── FETCH ALL RAW DATA ────────────────────────────────────────────────
    print("\n[1/4] Fetching datasources, connections, logins, projects...")

    ds_raw    = get_json(BASE_URL, auth_token, "/datasources")
    conn_raw  = get_json(BASE_URL, auth_token, "/datasources/connections")
    login_raw = get_json(BASE_URL, auth_token, "/datasources/logins")
    proj_raw  = get_json(BASE_URL, auth_token, "/projects")

    save_raw(ds_raw,    "raw_datasources.json")
    save_raw(conn_raw,  "raw_connections.json")
    save_raw(login_raw, "raw_logins.json")
    save_raw(proj_raw,  "raw_projects.json")
    print("  Raw JSON saved to raw_*.json files")

    # ── BUILD LOOKUP MAPS ─────────────────────────────────────────────────
    conn_map  = build_map(conn_raw,  "datasourceConnections", "connections")
    login_map = build_map(login_raw, "datasourceLogins",      "logins")

    # Normalise project list
    projects = proj_raw if isinstance(proj_raw, list) \
               else proj_raw.get("projects", [])

    # Normalise datasource list
    ds_list = ds_raw if isinstance(ds_raw, list) \
              else ds_raw.get("datasources",
                   ds_raw.get("datasourceInstances", []))

    print(f"  Found: {len(ds_list)} datasources | "
          f"{len(conn_map)} connections | "
          f"{len(login_map)} logins | "
          f"{len(projects)} projects")

    # ── PROJECT → DATASOURCE MAP ──────────────────────────────────────────
    print("\n[2/4] Mapping datasources to projects...")
    ds_to_projects, _ = build_project_datasource_map(
        BASE_URL, auth_token, projects
    )

    # ── DEPENDENCY CHECKS ─────────────────────────────────────────────────
    print(f"\n[3/4] Checking dependencies for {len(ds_list)} datasource(s)...")
    print("  (sequential — one at a time per MSTR API restriction)")

    dep_cache = {}   # datasource_id -> dep_list
    for i, ds in enumerate(ds_list, 1):
        ds_id   = ds.get("id", "")
        ds_name = ds.get("name", "")
        print(f"  [{i}/{len(ds_list)}] {ds_name}...", end=" ", flush=True)
        try:
            deps = check_dependencies(BASE_URL, auth_token, ds_id)
            dep_cache[ds_id] = deps
            print(f"{len(deps)} dependent(s)")
        except Exception as e:
            dep_cache[ds_id] = []
            print(f"⚠️  error: {e}")

    # ── BUILD CSV ROWS ────────────────────────────────────────────────────
    print(f"\n[4/4] Building CSV...")

    env_summary = {}
    rows = []

    for ds in ds_list:
        ds_id   = ds.get("id", "")
        ds_name = ds.get("name", "")

        # --- Connection info ---
        db_block    = ds.get("database", {})
        conn_ref    = db_block.get("connection", {})
        conn_id     = conn_ref.get("id", "")
        conn_detail = conn_map.get(conn_id, {})
        conn_name   = conn_detail.get("name",             conn_ref.get("name", ""))
        conn_string = conn_detail.get("connectionString", "")

        # --- Login info ---
        login_ref    = db_block.get("login", {})
        login_id     = login_ref.get("id", "")
        login_detail = login_map.get(login_id, {})
        login_name   = login_detail.get("name", login_ref.get("name", ""))

        # --- Environment flag ---
        env, matched_on = classify_datasource(
            ds_name, conn_name, login_name, conn_string
        )
        env_summary[env] = env_summary.get(env, 0) + 1

        # --- Project mapping ---
        proj_list     = ds_to_projects.get(ds_id, [])
        project_count = len(proj_list)
        project_names_str = " | ".join(proj_list) if proj_list else "not mapped to any project"

        # --- Dependencies ---
        dep_list              = dep_cache.get(ds_id, [])
        dep_count, dep_summary = format_dependencies(dep_list)

        # --- Safe to delete? ---
        safe_to_delete = "YES" if dep_count == 0 and project_count == 0 else "NO"

        rows.append({
            "datasource_id":       ds_id,
            "datasource_name":     ds_name,
            "environment":         env,
            "matched_on":          matched_on,
            "datasource_type":     ds.get("datasourceType", ""),
            "date_modified":       ds.get("dateModified", ""),
            # Connection
            "connection_id":       conn_id,
            "connection_name":     conn_name,
            "connection_string":   conn_string,
            # Login
            "login_id":            login_id,
            "login_name":          login_name,
            # Projects
            "project_count":       project_count,
            "projects":            project_names_str,
            # Dependencies
            "dependency_count":    dep_count,
            "dependencies":        dep_summary,
            # Summary
            "safe_to_delete":      safe_to_delete,
        })

    # ── WRITE CSV ─────────────────────────────────────────────────────────
    fieldnames = [
        "datasource_id",    "datasource_name",   "environment",
        "matched_on",       "datasource_type",   "date_modified",
        "connection_id",    "connection_name",   "connection_string",
        "login_id",         "login_name",
        "project_count",    "projects",
        "dependency_count", "dependencies",
        "safe_to_delete",
    ]

    with open(OUTPUT_CSV, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(rows)

    # ── SUMMARY ───────────────────────────────────────────────────────────
    safe_count    = sum(1 for r in rows if r["safe_to_delete"] == "YES")
    blocked_count = len(rows) - safe_count

    print(f"\n{'='*60}")
    print(f"  CSV written: {OUTPUT_CSV}  ({len(rows)} datasources)")
    print(f"{'='*60}")
    print(f"\n  Environment Breakdown:")
    for env, count in sorted(env_summary.items()):
        print(f"    {env:<10} {count}")
    print(f"    {'TOTAL':<10} {len(rows)}")
    print(f"\n  Deletion Safety:")
    print(f"    Safe to delete    {safe_count}")
    print(f"    Blocked           {blocked_count}")
    print(f"    (blocked = has dependencies or is mapped to at least one project)")

finally:
    mstr_logout(BASE_URL, auth_token)
