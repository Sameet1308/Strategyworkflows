def make_session() -> requests.Session:
s = requests.Session()
s.verify = False
s.headers.update({“Content-Type”: “application/json”, “Accept”: “application/json”})
return s

# —————————————————————————

# Auth

# —————————————————————————

def login(session: requests.Session) -> str:
“”“Authenticate and return the auth token.”””
url = f”{MSTR_BASE_URL}/api/auth/login”
payload = {
“username”: USERNAME,
“password”: PASSWORD,
“loginMode”: 1,          # 1 = Standard auth
}
resp = session.post(url, json=payload)
resp.raise_for_status()
token = resp.headers.get(“X-MSTR-AuthToken”)
if not token:
raise RuntimeError(“Login succeeded but no X-MSTR-AuthToken in response headers.”)
session.headers.update({“X-MSTR-AuthToken”: token})
log.info(“Logged in successfully. Auth token acquired.”)
return token

def logout(session: requests.Session) -> None:
url = f”{MSTR_BASE_URL}/api/auth/logout”
try:
session.post(url)
log.info(“Logged out successfully.”)
except Exception as exc:
log.warning(“Logout call failed (non-fatal): %s”, exc)

