def get_all_projects(session: requests.Session) -> list[dict]:
“”“Return list of all projects: [{id, name}, …]”””
url = f”{MSTR_BASE_URL}/api/projects”
resp = session.get(url)
resp.raise_for_status()
projects = resp.json()
log.info(“Found %d project(s) on the server.”, len(projects))
return projects

