# Device helpers

# —————————————————————————

def find_device_by_name(session: requests.Session, device_name: str, project_id: str = None) -> dict | None:
“””
Search for a device by exact name using the objects search API.
Returns the first match dict or None.
Object type 57 = Device in MSTR.
“””
headers = {}
if project_id:
headers[“X-MSTR-ProjectID”] = project_id

```
url = f"{MSTR_BASE_URL}/api/searches/results"
params = {
    "name":        device_name,
    "type":        57,           # Device object type
    "exactMatch":  True,
    "limit":       5,
}
resp = session.get(url, params=params, headers=headers)
resp.raise_for_status()
data = resp.json()
results = data.get("results", {}).get("objects", [])
for obj in results:
    if obj.get("name", "").strip().lower() == device_name.strip().lower():
        return obj
return None
```

def get_device_definition(session: requests.Session, device_id: str) -> dict:
“”“Fetch full device definition by ID.”””
url = f”{MSTR_BASE_URL}/api/devices/{device_id}”
resp = session.get(url)
resp.raise_for_status()
return resp.json()

def list_devices_in_project(session: requests.Session, project_id: str) -> list[dict]:
“”“List all devices visible within a project context.”””
url = f”{MSTR_BASE_URL}/api/devices”
headers = {“X-MSTR-ProjectID”: project_id}
resp = session.get(url, headers=headers)
resp.raise_for_status()
data = resp.json()
# Response may be a list or wrapped in a key
if isinstance(data, list):
return data
return data.get(“devices”, data.get(“items”, []))

def device_exists_in_project(session: requests.Session, project_id: str, device_name: str) -> bool:
“”“Return True if a device with device_name already exists in the project.”””
devices = list_devices_in_project(session, project_id)
names = [d.get(“name”, “”).strip().lower() for d in devices]
return device_name.strip().lower() in names

def create_device(session: requests.Session, project_id: str, new_name: str, reference_def: dict) -> dict:
“””
POST a new device to the given project, cloning the reference definition
but with a new name.
“””
url = f”{MSTR_BASE_URL}/api/devices”
headers = {“X-MSTR-ProjectID”: project_id}

```
# Build payload — strip read-only fields, replace name
payload = {
    "name":        new_name,
    "description": reference_def.get("description", ""),
    "deviceType":  reference_def.get("deviceType"),       # File device type int
    "deviceProperties": reference_def.get("deviceProperties", {}),
}

# Some MSTR versions nest config under 'settings' or 'properties'
for extra_key in ("settings", "properties", "outputFormat"):
    if extra_key in reference_def:
        payload[extra_key] = reference_def[extra_key]

resp = session.post(url, json=payload, headers=headers)
resp.raise_for_status()
return resp.json()
```

# —————————————————————————

# Name helpers

# —————————————————————————

def build_new_device_name(reference_name: str, project_name: str) -> str:
“””
Replace the suffix (after the last ’ - ’) of the reference device name
with the project name.

```
Example:
    reference_name = "File Device - ProjectAlpha"
    project_name   = "ProjectBeta"
    returns        = "File Device - ProjectBeta"

If no ' - ' separator is found, appends ' - <ProjectName>'.
"""
sep = " - "
if sep in reference_name:
    prefix = reference_name.rsplit(sep, 1)[0]
    return f"{prefix}{sep}{project_name}"
return f"{reference_name}{sep}{project_name}"
```

