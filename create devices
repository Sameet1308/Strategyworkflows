# —————————————————————————

def parse_args() -> argparse.Namespace:
parser = argparse.ArgumentParser(
description=“Replicate a MicroStrategy File Device across all projects.”
)
parser.add_argument(
“–reference-device”,
required=True,
metavar=“DEVICE_NAME”,
help=‘Exact name of the reference device, e.g. “File Device - ProjectAlpha”’,
)
return parser.parse_args()

def main() -> None:
args = parse_args()
reference_name: str = args.reference_device

```
log.info("=" * 60)
log.info("MSTR Device Replicator")
log.info("Reference device : %s", reference_name)
log.info("Target server    : %s", MSTR_BASE_URL)
log.info("=" * 60)

session = make_session()

# --- Login ---
try:
    login(session)
except Exception as exc:
    log.error("Login failed: %s", exc)
    sys.exit(1)

try:
    # --- Fetch reference device (server-level search, no project context) ---
    log.info("Searching for reference device '%s' ...", reference_name)
    ref_obj = find_device_by_name(session, reference_name)
    if not ref_obj:
        log.error(
            "Reference device '%s' not found on the server. "
            "Check the name and ensure the user has access.",
            reference_name,
        )
        sys.exit(1)

    ref_id = ref_obj["id"]
    log.info("Reference device found. ID: %s", ref_id)

    ref_def = get_device_definition(session, ref_id)
    log.info("Reference device definition fetched successfully.")
    log.debug("Reference definition:\n%s", json.dumps(ref_def, indent=2))

    # --- Fetch all projects ---
    projects = get_all_projects(session)
    if not projects:
        log.warning("No projects returned from the server. Nothing to do.")
        sys.exit(0)

    # --- Summary counters ---
    created  = 0
    skipped  = 0
    failed   = 0

    for project in projects:
        proj_id   = project.get("id")
        proj_name = project.get("name", "").strip()

        if not proj_id or not proj_name:
            log.warning("Skipping project with missing id/name: %s", project)
            continue

        new_device_name = build_new_device_name(reference_name, proj_name)

        log.info("-" * 50)
        log.info("Project  : %s  (%s)", proj_name, proj_id)
        log.info("New name : %s", new_device_name)

        # --- Check if device already exists ---
        try:
            already_exists = device_exists_in_project(session, proj_id, new_device_name)
        except Exception as exc:
            log.warning(
                "Could not check existing devices for project '%s': %s — skipping.",
                proj_name, exc,
            )
            failed += 1
            continue

        if already_exists:
            log.info("SKIPPED — device '%s' already exists in project '%s'.",
                     new_device_name, proj_name)
            skipped += 1
            continue

        # --- Create device ---
        try:
            result = create_device(session, proj_id, new_device_name, ref_def)
            new_id = result.get("id", "unknown")
            log.info("CREATED — '%s'  (new ID: %s)", new_device_name, new_id)
            created += 1
        except requests.HTTPError as exc:
            status = exc.response.status_code if exc.response is not None else "?"
            body   = exc.response.text[:400] if exc.response is not None else ""
            log.error(
                "FAILED  — Could not create device for project '%s'. "
                "HTTP %s: %s",
                proj_name, status, body,
            )
            failed += 1
        except Exception as exc:
            log.error("FAILED  — Unexpected error for project '%s': %s", proj_name, exc)
            failed += 1

    # --- Final summary ---
    log.info("=" * 60)
    log.info("DONE. Created: %d | Skipped: %d | Failed: %d", created, skipped, failed)
    log.info("Full log saved to: mstr_create_devices.log")
    log.info("=" * 60)

finally:
    logout(session)
```

if **name** == “**main**”:
main()