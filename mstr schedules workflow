def main():
ap = argparse.ArgumentParser(
description=“Strategy ONE Schedule Manager — scan, approve, and fix expired schedules.”
)
ap.add_argument(”–host”,     default=MSTR_HOST,     help=f”Library URL (default: {MSTR_HOST})”)
ap.add_argument(”–user”,     default=MSTR_USER,     help=f”Username (default: {MSTR_USER})”)
ap.add_argument(”–password”, default=MSTR_PASSWORD, help=“Password (default: from config block)”)
ap.add_argument(”–mock”, action=“store_true”, help=“Use built-in mock data (no server needed)”)
args = ap.parse_args()

```
if not args.mock and not all([args.host, args.user, args.password]):
    ap.print_help()
    print("\n  ERROR: Fill in MSTR_HOST / MSTR_USER / MSTR_PASSWORD in the config block at the top, or pass --host --user --password flags.\n")
    sys.exit(1)

# ── Banner ───────────────────────────────────────────
