def write_audit(
healthy: list, problem: list, approved: list,
success: list, failure: list,
):
path = AUDIT_FILE_FMT.format(ts=ts_now())
approved_ids = {s[“id”] for s in approved}
data = {
“product”     : “Strategy ONE (September 2025)”,
“run_at”      : datetime.now().isoformat(),
“summary”     : {
“total_scanned”: len(healthy) + len(problem),
“healthy”      : len(healthy),
“expired”      : len(problem),
“approved”     : len(approved),
“fixed”        : len(success),
“failed”       : len(failure),
“skipped”      : len(problem) - len(approved),
},
“fixed”   : success,
“failed”  : failure,
“skipped” : [
{“id”: s[“id”], “name”: s.get(“name”)}
for s in problem if s[“id”] not in approved_ids
],
}
with open(path, “w”) as f:
json.dump(data, f, indent=2)
print(f”  ✎  Audit log → {path}\n”)

