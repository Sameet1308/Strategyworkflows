print(W(74))
print("  STRATEGY ONE  —  SCHEDULE MANAGER")
print("  Version: September 2025  (11.5.9)")
mode = "MOCK MODE — no server" if args.mock else args.host
print(f"  Mode: {mode}")
print(W(74))

session: Optional[StrategyOneSession] = None

try:
    # ── Step 1: Login + Fetch ────────────────────────
    if args.mock:
        schedules = MOCK_SCHEDULES
        print(f"\n  Loaded {len(schedules)} mock schedules.\n")
    else:
        session = StrategyOneSession(args.host)
        print()
        session.login(args.user, args.password)
        print("  Fetching schedules...")
        schedules = session.list_schedules()
        print(f"  Found {len(schedules)} schedule(s).\n")

    # ── Step 2: Classify ─────────────────────────────
    healthy, problem = classify(schedules)

    # ── Step 3: Report ───────────────────────────────
    print_report(healthy, problem)

    if not problem:
        return  # nothing to do

    # ── Step 4: Approve ──────────────────────────────
    approved = prompt_approval(problem)

    # ── Step 5: Fix ──────────────────────────────────
    success, failure = fix_schedules(approved, session=session, mock=args.mock)

    # ── Step 6: Summary ──────────────────────────────
    skipped = len(problem) - len(approved)
    print_summary(success, failure, skipped)

    # ── Step 7: Audit log ────────────────────────────
    write_audit(healthy, problem, approved, success, failure)

finally:
    if session:
        session.logout()
