def classify(schedules: list[dict]) -> tuple[list[dict], list[dict]]:
“””
healthy  — expired=false  AND  (no stopDate OR stopDate >= today)
problem  — expired=true   OR   stopDate < today
“””
today   = date.today()
healthy = []
problem = []

```
for s in schedules:
    reasons = []

    # 1. Server-side expired flag (most reliable)
    if s.get("expired") is True:
        reasons.append("expired=true (server flag)")

    # 2. Independent stopDate check (catches stale flags)
    stop_raw = s.get("stopDate")
    if stop_raw:
        stop_dt = parse_date_safe(stop_raw)
        if stop_dt and stop_dt < today:
            if not reasons:  # avoid double-labelling
                reasons.append(f"stopDate {stop_raw} is in the past")

    if reasons:
        s["_reasons"] = reasons
        problem.append(s)
    else:
        healthy.append(s)

return healthy, problem
```

