class StrategyOneSession:
“”“Thin wrapper around requests for Strategy ONE REST API.”””

```
def __init__(self, base_url: str):
    self.base_url = base_url.rstrip("/")
    self._s = requests.Session()
    self._s.verify = SSL_VERIFY   # controlled by the config block at the top
    self._s.headers.update({"Content-Type": "application/json"})
    self.token: Optional[str] = None

# ── Auth ──────────────────────────────────────────────

def login(self, username: str, password: str):
    """POST /api/auth/login  →  store X-MSTR-AuthToken header."""
    resp = self._s.post(
        f"{self.base_url}/api/auth/login",
        json={"username": username, "password": password, "loginMode": 1},
        timeout=30,
    )
    resp.raise_for_status()
    self.token = resp.headers.get("X-MSTR-AuthToken")
    if not self.token:
        raise ValueError(
            "Login did not return X-MSTR-AuthToken. "
            "Check credentials and loginMode."
        )
    self._s.headers["X-MSTR-AuthToken"] = self.token
    print(f"  ✓  Logged in  →  {self.base_url}")

def logout(self):
    if self.token:
        try:
            self._s.post(f"{self.base_url}/api/auth/logout", timeout=10)
            print("  ✓  Session closed")
        except Exception:
            pass

# ── Schedules ────────────────────────────────────────

def list_schedules(self) -> list[dict]:
    """GET /api/schedules  (paginated, 200 per page)."""
    all_items, offset, limit = [], 0, 200
    while True:
        r = self._s.get(
            f"{self.base_url}/api/schedules",
            params={"offset": offset, "limit": limit},
            timeout=30,
        )
        r.raise_for_status()
        batch = r.json().get("schedules", [])
        all_items.extend(batch)
        if len(batch) < limit:
            break
        offset += limit
    return all_items

def get_schedule(self, schedule_id: str) -> dict:
    """GET /api/schedules/{id}  →  full object for round-trip PUT."""
    r = self._s.get(f"{self.base_url}/api/schedules/{schedule_id}", timeout=30)
    r.raise_for_status()
    return r.json()

def put_schedule(self, schedule_id: str, body: dict) -> bool:
    """PUT /api/schedules/{id}  →  True on 200/204."""
    r = self._s.put(
        f"{self.base_url}/api/schedules/{schedule_id}",
        json=body,
        timeout=30,
    )
    return r.status_code in (200, 204)
