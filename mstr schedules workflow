# STEP 5 — FIX

# ─────────────────────────────────────────────────────────

def fix_schedules(
approved: list[dict],
session: Optional[StrategyOneSession],
mock: bool,
) -> tuple[list[dict], list[dict]]:
“””
For each approved schedule:
• GET full object  (preserves time/event recurrence block)
• Patch startDate + stopDate
• PUT it back
Returns (success_list, failure_list).
“””
new_start = today_str()
new_stop  = future_str()

```
print(W(74))
print("  APPLYING FIXES")
print(W(74))
print(f"  startDate → {new_start}")
print(f"  stopDate  → {new_stop}")
print()

success, failure = [], []

for s in approved:
    sid  = s["id"]
    name = s.get("name", sid)
    print(f"  ▶  {name}")
    print(f"     ID: {sid}")

    try:
        if mock:
            # Simulate full round-trip with mock object
            full = dict(s)
        else:
            # Step A: fetch full object (we need the time/event block)
            full = session.get_schedule(sid)

        # Step B: apply new dates
        full["startDate"] = new_start
        full["stopDate"]  = new_stop
        # Remove read-only fields the server rejects on PUT
        for ro in ("expired", "scheduleNextDelivery", "acg"):
            full.pop(ro, None)

        # Step C: PUT it back
        ok = True if mock else session.put_schedule(sid, full)

        if ok:
            print(f"     ✓  Fixed  {s.get('stopDate', '?')} → {new_stop}")
            success.append({"id": sid, "name": name,
                            "old_stopDate": s.get("stopDate"),
                            "new_startDate": new_start,
                            "new_stopDate": new_stop})
        else:
            print(f"     ✗  PUT returned non-200 — check server logs")
            failure.append({"id": sid, "name": name, "error": "non-200 response"})

    except requests.HTTPError as e:
        msg = f"HTTP {e.response.status_code}: {e.response.text[:160]}"
        print(f"     ✗  {msg}")
        failure.append({"id": sid, "name": name, "error": msg})
    except Exception as e:
        print(f"     ✗  {e}")
        failure.append({"id": sid, "name": name, "error": str(e)})

    print()

return success, failure
```

