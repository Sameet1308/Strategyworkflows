```
while True:
    raw = input("  Your choice: ").strip().upper()

    if raw == "Q":
        print("\n  Aborted — no changes made.\n")
        sys.exit(0)

    if raw == "A":
        print(f"\n  ✓  All {len(problem)} schedules approved.\n")
        return problem

    try:
        indices  = [int(x.strip()) for x in raw.split(",") if x.strip()]
        selected = []
        for idx in indices:
            if 1 <= idx <= len(problem):
                selected.append(problem[idx - 1])
            else:
                print(f"  ⚠  Row {idx} is out of range — skipped.")
        if selected:
            names = ", ".join(s["name"] for s in selected)
            print(f"\n  ✓  Approved {len(selected)}: {names}\n")
            return selected
        print("  No valid rows selected — try again.")
    except ValueError:
        print("  Invalid input. Enter A, Q, or numbers like 1,3,5.")
