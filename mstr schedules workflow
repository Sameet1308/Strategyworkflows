def W(n: int) -> str:
return “═” * n

def today_str() -> str:
return date.today().strftime(DATE_FMT)

def future_str() -> str:
return (date.today() + timedelta(days=365 * EXTEND_YEARS)).strftime(DATE_FMT)

def parse_date_safe(s: str) -> Optional[date]:
try:
return datetime.strptime(s, DATE_FMT).date()
except Exception:
return None

def ts_now() -> str:
return datetime.now().strftime(”%Y%m%d_%H%M%S”)

